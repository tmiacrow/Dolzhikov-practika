<!DOCTYPE html>
<html lang="ru">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#2d0a4a" />
  <title>NIMMI — каталог</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,600;0,700;0,800;1,600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --neon: #39ff14;
      --green-header: #4ade80;
      --green-btn: #22c55e;
      --purple-deep: #1e0b3a;
      --purple-mid: #5b21b6;
      --btn-purple: #9333ea;
      --btn-purple-hover: #7e22ce;
      --price-bg: #fde047;
      --price-text: #dc2626;
      --nav-bg: #0a0a0a;
      --nav-ink: #f1f5f9;
      --nav-muted: rgba(241, 245, 249, 0.55);
      --nav-active: #f472b6;
      --splash-dark: #052e16;
      --radius-lg: 24px;
      --radius-md: 18px;
      --radius-sm: 14px;
      --content-max: 1280px;
    }

    *,
    *::before,
    *::after {
      box-sizing: border-box;
    }

    html,
    body {
      height: 100%;
      margin: 0;
    }

    body {
      font-family: "Inter", system-ui, -apple-system, sans-serif;
      color: #f8fafc;
      -webkit-font-smoothing: antialiased;
      background: linear-gradient(180deg, var(--neon) 0%, #16a34a 14%, var(--purple-mid) 48%, var(--purple-deep) 100%);
      background-attachment: fixed;
      min-height: 100%;
    }

    button {
      font: inherit;
      cursor: pointer;
      border: none;
      background: none;
      color: inherit;
    }

    :focus-visible {
      outline: 2px solid var(--neon);
      outline-offset: 2px;
    }

    .app-frame {
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    .top-nav {
      position: sticky;
      top: 0;
      z-index: 100;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: clamp(8px, 4vw, 48px);
      padding: 12px 20px;
      background: var(--nav-bg);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.45);
    }

    .top-nav.is-hidden {
      display: none;
    }

    .top-nav__inner {
      width: 100%;
      max-width: var(--content-max);
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      flex-wrap: wrap;
    }

    .top-nav__brand {
      font-family: "Inter", sans-serif;
      font-weight: 800;
      letter-spacing: 0.14em;
      font-size: 0.95rem;
      color: #fff;
      flex-shrink: 0;
    }

    .top-nav__tabs {
      display: flex;
      align-items: center;
      gap: 4px;
      flex-shrink: 0;
    }

    .nav-tab {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 4px;
      padding: 8px 12px;
      border-radius: 14px;
      color: var(--nav-muted);
      font-size: 0.6rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      transition: color 0.15s ease, background 0.15s ease;
    }

    .nav-tab svg {
      width: 22px;
      height: 22px;
      stroke-width: 1.75;
    }

    .nav-tab:hover {
      color: rgba(255, 255, 255, 0.9);
      background: rgba(255, 255, 255, 0.06);
    }

    .nav-tab.is-current {
      color: var(--nav-active);
    }

    .nav-tab.is-current svg {
      stroke: var(--nav-active);
    }

    .main-area {
      flex: 1;
      width: 100%;
      max-width: var(--content-max);
      margin: 0 auto;
      padding: clamp(16px, 2.5vw, 32px);
      display: flex;
      flex-direction: column;
      min-height: min(100vh, 100%);
    }

    .screen {
      display: none;
      flex-direction: column;
      flex: 1;
      animation: fadeIn 0.28s ease;
    }

    .screen.is-active {
      display: flex;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    @media (prefers-reduced-motion: reduce) {
      .screen {
        animation: none;
      }
    }

    .screen--splash {
      position: fixed;
      inset: 0;
      z-index: 200;
      justify-content: center;
      align-items: center;
      text-align: center;
      padding: 48px 24px;
      background: linear-gradient(180deg, #0d4d2c 0%, #020617 100%);
    }

    .logo-ring {
      width: min(240px, 40vw);
      aspect-ratio: 1;
      border-radius: 50%;
      display: flex;
      justify-content: center;
      align-items: center;
      background: transparent;
      border: none;
      box-shadow: none;
      margin-bottom: auto;
      margin-top: 8vh;
    }

    .logo-ring img {
      width: 100%;
      height: 100%;
      object-fit: contain;
      border-radius: 50%;
    }

    .logo-ring h1 {
      margin: 0;
      font-family: "Inter", sans-serif;
      font-size: clamp(1.75rem, 4vw, 2.5rem);
      font-weight: 800;
      letter-spacing: 0.1em;
      color: #fff;
    }

    .logo-icons {
      font-size: 1.25rem;
      margin-bottom: 8px;
    }

    .btn-go {
      width: min(360px, 90vw);
      padding: 18px 28px;
      border-radius: var(--radius-lg);
      background: var(--btn-purple);
      color: #fff;
      font-weight: 700;
      font-size: 1.1rem;
      box-shadow: 0 14px 40px rgba(147, 51, 234, 0.45);
      transition: transform 0.15s ease, background 0.15s ease;
    }

    .btn-go:hover {
      background: var(--btn-purple-hover);
    }

    .btn-go:active {
      transform: scale(0.98);
    }

    .page-head {
      display: flex;
      align-items: center;
      gap: 12px;
      min-height: 56px;
      padding: 0 18px;
      margin-bottom: 20px;
      border-radius: 999px;
      background: var(--green-header);
      box-shadow: 0 8px 28px rgba(0, 0, 0, 0.2);
    }

    .page-head--center {
      justify-content: center;
    }

    .page-head h2 {
      margin: 0;
      flex: 1;
      text-align: center;
      font-family: "Playfair Display", Georgia, serif;
      font-size: clamp(1.25rem, 2vw, 1.6rem);
      font-weight: 700;
      color: #fff;
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }

    .page-head h2:not(:only-child) {
      padding-right: 44px;
    }

    .page-head .icon-btn {
      background: rgba(5, 46, 22, 0.28);
      color: #fff;
    }

    .page-head .icon-btn:hover {
      background: rgba(5, 46, 22, 0.42);
    }

    .icon-btn {
      width: 44px;
      height: 44px;
      border-radius: 12px;
      display: grid;
      place-items: center;
      background: rgba(15, 23, 42, 0.08);
      color: #0f172a;
      flex-shrink: 0;
    }

    .icon-btn:hover {
      background: rgba(15, 23, 42, 0.14);
    }

    .scroll {
      flex: 1;
      overflow-y: auto;
      padding-bottom: 24px;
    }

    .grid-cats {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 20px;
    }

    @media (min-width: 1100px) {
      .grid-cats {
        grid-template-columns: repeat(3, 1fr);
      }
    }

    .cat-card {
      display: flex;
      align-items: stretch;
      gap: 16px;
      padding: 16px;
      border-radius: var(--radius-md);
      border: 2px solid rgba(255, 255, 255, 0.45);
      background: rgba(15, 23, 42, 0.28);
      backdrop-filter: blur(12px);
      text-align: left;
      width: 100%;
      min-height: 120px;
      transition: border-color 0.15s ease, transform 0.15s ease;
    }

    .cat-card:hover {
      border-color: rgba(255, 255, 255, 0.85);
      transform: translateY(-2px);
    }

    .cat-thumb {
      width: 100px;
      height: 100px;
      border-radius: var(--radius-sm);
      object-fit: cover;
      flex-shrink: 0;
      background: rgba(0, 0, 0, 0.3);
    }

    .cat-thumb--emoji {
      display: grid;
      place-items: center;
      font-size: 3rem;
    }

    .cat-title-h {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: flex-start;
      font-family: "Playfair Display", Georgia, serif;
      font-weight: 700;
      font-size: 1.25rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: #fff;
      text-align: left;
      padding-left: 4px;
    }

    .grid-rows {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 14px;
    }

    @media (min-width: 1200px) {
      .grid-rows {
        grid-template-columns: repeat(4, 1fr);
      }
    }

    .list-row {
      display: flex;
      align-items: center;
      gap: 14px;
      width: 100%;
      padding: 14px 16px;
      border-radius: var(--radius-md);
      border: 1px solid rgba(255, 255, 255, 0.25);
      background: rgba(15, 23, 42, 0.25);
      backdrop-filter: blur(8px);
      text-align: left;
      transition: background 0.15s ease, border-color 0.15s ease;
    }

    .list-row:hover {
      background: rgba(15, 23, 42, 0.4);
      border-color: rgba(255, 255, 255, 0.45);
    }

    .row-thumb {
      width: 64px;
      height: 64px;
      border-radius: 50%;
      object-fit: cover;
      flex-shrink: 0;
      background: rgba(0, 0, 0, 0.3);
    }

    .row-thumb--emoji {
      display: grid;
      place-items: center;
      font-size: 1.85rem;
    }

    .row-text {
      font-family: "Playfair Display", Georgia, serif;
      font-weight: 600;
      font-size: 1.05rem;
      letter-spacing: 0.03em;
      text-transform: uppercase;
      color: #f8fafc;
    }

    .row-meta {
      margin-left: auto;
      font-weight: 600;
      color: rgba(248, 250, 252, 0.75);
      font-size: 0.9rem;
    }

    .product-layout {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: clamp(20px, 3vw, 40px);
      align-items: start;
    }

    @media (max-width: 768px) {
      .product-layout {
        grid-template-columns: 1fr;
      }
    }

    .hero-img {
      width: 100%;
      aspect-ratio: 1;
      border-radius: var(--radius-lg);
      object-fit: cover;
      display: block;
      background: rgba(0, 0, 0, 0.35);
      border: 2px solid rgba(255, 255, 255, 0.2);
    }

    .detail-body h3 {
      margin: 0 0 16px;
      font-family: "Playfair Display", Georgia, serif;
      font-size: clamp(1.75rem, 3vw, 2.5rem);
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: #fff;
    }

    .detail-body p {
      margin: 0 0 24px;
      color: rgba(248, 250, 252, 0.88);
      line-height: 1.6;
      font-size: 1rem;
    }

    .price-tag {
      display: inline-block;
      padding: 12px 20px;
      border-radius: var(--radius-md);
      background: var(--price-bg);
      color: var(--price-text);
      font-weight: 700;
      font-size: 1.1rem;
      box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
    }

    .detail-actions {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 16px;
      margin-top: 8px;
    }

    .btn-cart {
      padding: 16px 28px;
      border-radius: 999px;
      background: var(--green-btn);
      color: #fff;
      font-weight: 700;
      font-size: 0.95rem;
      letter-spacing: 0.02em;
      box-shadow: 0 10px 32px rgba(34, 197, 94, 0.4);
      transition: background 0.15s ease, transform 0.12s ease;
    }

    .btn-cart:hover {
      background: #16a34a;
    }

    .btn-cart:active {
      transform: scale(0.98);
    }

    .profile-wrap {
      max-width: 560px;
      margin: 0 auto;
      width: 100%;
    }

    .profile-avatar {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      margin: 0 auto 28px;
      object-fit: cover;
      border: 4px solid rgba(255, 255, 255, 0.5);
      display: block;
      box-shadow: 0 12px 40px rgba(0, 0, 0, 0.3);
    }

    .profile-menu {
      border-radius: var(--radius-md);
      overflow: hidden;
      border: 1px solid rgba(255, 255, 255, 0.25);
      background: rgba(15, 23, 42, 0.35);
      backdrop-filter: blur(10px);
    }

    .profile-row {
      display: flex;
      align-items: center;
      gap: 14px;
      width: 100%;
      padding: 16px 18px;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
      color: #f8fafc;
      text-align: left;
      font-size: 1rem;
      transition: background 0.12s ease;
    }

    .profile-row:last-child {
      border-bottom: none;
    }

    .profile-row:hover {
      background: rgba(255, 255, 255, 0.06);
    }

    .profile-row span.icon {
      font-size: 1.35rem;
      width: 32px;
      text-align: center;
    }

    .cart-empty {
      text-align: center;
      padding: 48px 24px;
      border-radius: var(--radius-lg);
      border: 2px dashed rgba(255, 255, 255, 0.35);
      background: rgba(15, 23, 42, 0.2);
    }

    .cart-empty .big-icon {
      font-size: 4rem;
      margin-bottom: 16px;
      opacity: 0.9;
    }

    .cart-empty p {
      margin: 0;
      font-size: 1.1rem;
      color: rgba(248, 250, 252, 0.9);
      max-width: 420px;
      margin-inline: auto;
      line-height: 1.55;
    }

    .cart-list {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .cart-item {
      display: flex;
      align-items: center;
      gap: 16px;
      padding: 14px 18px;
      border-radius: var(--radius-md);
      border: 1px solid rgba(255, 255, 255, 0.2);
      background: rgba(15, 23, 42, 0.3);
      position: relative;
    }

    .cart-item img,
    .cart-item .emoji {
      width: 56px;
      height: 56px;
      border-radius: 12px;
      object-fit: cover;
      flex-shrink: 0;
    }

    .cart-item .emoji {
      display: grid;
      place-items: center;
      font-size: 1.75rem;
      background: rgba(0, 0, 0, 0.25);
    }

    .cart-item .name {
      font-family: "Playfair Display", Georgia, serif;
      font-weight: 600;
      font-size: 1.05rem;
      flex: 1;
    }

    .cart-item .price {
      font-weight: 700;
      color: var(--price-bg);
    }

    .cart-item .delete-item-btn {
      background: rgba(220, 38, 38, 0.8);
      color: white;
      border: none;
      border-radius: 8px;
      padding: 6px 12px;
      font-size: 0.8rem;
      cursor: pointer;
      transition: background 0.2s;
      margin-left: 12px;
    }

    .cart-item .delete-item-btn:hover {
      background: #dc2626;
    }

    .cart-total {
      margin-top: 20px;
      padding: 16px;
      text-align: right;
      border-top: 2px solid rgba(255, 255, 255, 0.2);
      font-size: 1.2rem;
      font-weight: 700;
    }

    .cart-total span {
      color: var(--price-bg);
      font-size: 1.4rem;
    }

    .search-panel {
      max-width: 640px;
      margin: 0 auto;
      width: 100%;
    }

    .search-label {
      display: block;
      font-size: 0.9rem;
      font-weight: 600;
      color: rgba(248, 250, 252, 0.85);
      margin-bottom: 8px;
    }

    .search-field {
      width: 100%;
      padding: 14px 18px;
      border-radius: 16px;
      border: 2px solid rgba(255, 255, 255, 0.28);
      background: rgba(15, 23, 42, 0.45);
      color: #fff;
      font-size: 1rem;
    }

    .search-field::placeholder {
      color: rgba(255, 255, 255, 0.45);
    }

    .search-hint {
      margin: 10px 0 16px;
      font-size: 0.88rem;
      color: rgba(248, 250, 252, 0.72);
    }

    .search-results {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .search-hit {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 4px;
      width: 100%;
      padding: 14px 16px;
      border-radius: var(--radius-md);
      border: 1px solid rgba(255, 255, 255, 0.22);
      background: rgba(15, 23, 42, 0.38);
      text-align: left;
      color: #f8fafc;
      transition: background 0.12s ease, border-color 0.12s ease;
    }

    .search-hit:hover {
      background: rgba(15, 23, 42, 0.55);
      border-color: rgba(255, 255, 255, 0.4);
    }

    .search-hit__title {
      font-family: "Playfair Display", Georgia, serif;
      font-weight: 600;
      font-size: 1.1rem;
      letter-spacing: 0.03em;
    }

    .search-hit__meta {
      font-size: 0.82rem;
      color: rgba(248, 250, 252, 0.65);
    }

    .search-empty {
      margin: 0;
      padding: 20px;
      text-align: center;
      color: rgba(248, 250, 252, 0.75);
      font-size: 0.95rem;
    }

    .toast {
      position: fixed;
      left: 50%;
      bottom: 32px;
      transform: translateX(-50%) scale(0.96);
      background: rgba(15, 23, 42, 0.95);
      color: #fff;
      padding: 12px 22px;
      border-radius: 999px;
      font-size: 0.9rem;
      font-weight: 600;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.2s ease, transform 0.2s ease;
      z-index: 300;
      max-width: min(90vw, 480px);
      text-align: center;
      border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .toast.show {
      opacity: 1;
      transform: translateX(-50%) scale(1);
    }

    .sr-only {
      position: absolute;
      width: 1px;
      height: 1px;
      padding: 0;
      margin: -1px;
      overflow: hidden;
      clip: rect(0, 0, 0, 0);
      white-space: nowrap;
      border: 0;
    }
  </style>
</head>
<body>
  <div class="app-frame" id="app">
    <nav class="top-nav is-hidden" id="topNav" aria-label="Главное меню">
      <div class="top-nav__inner">
        <span class="top-nav__brand">NIMMI</span>
        <div class="top-nav__tabs">
          <button type="button" class="nav-tab is-current" data-tab="catalog" aria-current="page">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
              <path d="M4 6h16M4 12h16M4 18h10" stroke-linecap="round" />
            </svg>
            Каталог
          </button>
          <button type="button" class="nav-tab" data-tab="search">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
              <circle cx="11" cy="11" r="7" fill="none" stroke-width="2" />
              <path d="M20 20l-3-3" stroke-linecap="round" stroke-width="2" />
            </svg>
            Поиск
          </button>
          <button type="button" class="nav-tab" data-tab="profile">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
              <path d="M12 12a4 4 0 100-8 4 4 0 000 8z" />
              <path d="M4 21a8 8 0 0116 0" stroke-linecap="round" />
            </svg>
            Профиль
          </button>
          <button type="button" class="nav-tab" data-tab="cart">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" aria-hidden="true">
              <circle cx="9" cy="20" r="1.5" fill="currentColor" stroke="none" />
              <circle cx="18" cy="20" r="1.5" fill="currentColor" stroke="none" />
              <path d="M3 4h2l1 12h12l2-9H6" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
            Корзина
          </button>
        </div>
      </div>
    </nav>

    <main class="main-area">
      <!-- Splash -->
      <section class="screen screen--splash is-active" id="screen-splash" aria-label="Приветствие">
        <div class="logo-ring">
          <img src="https://1s4oyld5dc.ucarecd.net/0aa8e611-9a34-4030-85a4-ef3f90ed3b5a/" alt="NIMMI Logo" />
        </div>
        <button type="button" class="btn-go" data-action="enter">Погнали</button>
      </section>

      <!-- Каталог -->
      <section class="screen" id="screen-catalog" aria-label="Каталог">
        <header class="page-head page-head--center">
          <h2>Каталог</h2>
        </header>
        <div class="scroll">
          <div class="grid-cats">
            <button type="button" class="cat-card" data-nav="fruits">
              <img class="cat-thumb" src="https://i.pinimg.com/736x/fa/5a/1b/fa5a1b50491bd61fb2909d30b82ca252.jpg" alt="Фрукты" loading="lazy" />
              <div class="cat-title-h">Фрукты</div>
            </button>
            <button type="button" class="cat-card" data-nav="vegetables">
              <img class="cat-thumb" src="https://i1-c.pinimg.com/1200x/f9/ce/6b/f9ce6b6ce9140da9179756227f615535.jpg" alt="Овощи" loading="lazy" />
              <div class="cat-title-h">Овощи</div>
            </button>
            <button type="button" class="cat-card" data-nav="bakery">
              <img class="cat-thumb" src="https://i1-c.pinimg.com/1200x/a8/25/d4/a825d4379809657ef57af5d3f45aa825.jpg" alt="Выпечка" loading="lazy" />
              <div class="cat-title-h">Выпечка</div>
            </button>
          </div>
        </div>
